# ─────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your real credentials
#  NEVER commit the real .env to version control
# ─────────────────────────────────────────────────────────

# CoinDCX API (for order execution: buy/sell)
# Get your keys at: https://coindcx.com/settings/api
COINDCX_API_KEY=your_coindcx_api_key_here
COINDCX_API_SECRET=your_coindcx_api_secret_here

# Telegram Bot
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Get your chat ID: message @userinfobot or check your chat URL
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Dashboard defaults (Binance symbol format, e.g. BTCUSDT, ETHUSDT)
SYMBOL=BTCUSDT
INTERVAL=1m

# SQLite database path (relative to project root)
DB_PATH=data/trading.db

# Dashboard port
PORT=8000

# Trading phase:
#   1 = Manual  — signal alerts only, you trade manually via dashboard or /buy /sell Telegram commands
#   2 = Semi-auto — HIGH confidence signals ask for Telegram approval before executing
#   3 = Full-auto — all HIGH confidence signals execute automatically
TRADING_PHASE=1

# Risk management (used in Phase 2+)
MAX_POSITION_PCT=0.02    # 2% of USDT balance per trade
STOP_LOSS_PCT=0.015      # 1.5% stop-loss
TAKE_PROFIT_PCT=0.030    # 3.0% take-profit

# ── Email / SMTP (OPTIONAL — needed for forgot-password emails) ────────────────
# Leave blank to disable email features (forgot-password will silently skip)
# Gmail example: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_USER=you@gmail.com
#                SMTP_PASS=your-app-password (not regular password — create in Google account settings)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Auth secrets (REQUIRED) ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-random-hex

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: changing this key makes stored CoinDCX API keys unreadable — back it up!
FERNET_KEY=replace-with-fernet-generated-key
